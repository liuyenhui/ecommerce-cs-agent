FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_ENV=production \
    SERVICE_NAME=ecommerce-cs-agent-api \
    PORT=8000

WORKDIR /opt/app

RUN addgroup --system --gid 10001 app && adduser --system --uid 10001 --ingroup app --home /opt/app app \
    && chown -R app:app /opt/app

COPY --chown=app:app pyproject.toml README.md ./
COPY --chown=app:app ecommerce_cs_agent ./ecommerce_cs_agent
COPY --chown=app:app migrations ./migrations

RUN pip install --no-cache-dir \
        "fastapi>=0.115,<1" \
        "uvicorn>=0.34,<1" \
        "pydantic>=2.8,<3" \
        "psycopg[binary]>=3.2,<4" \
        "bcrypt>=4.1,<5" \
        "langgraph>=1.2,<2" \
        "cryptography>=45,<47" \
    && pip install --no-cache-dir --no-deps .

USER 10001:10001

EXPOSE 8000

CMD ["sh", "-c", "uvicorn ecommerce_cs_agent.api.app:app --host 0.0.0.0 --port ${PORT:-8000}"]
