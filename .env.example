# ecommerce-cs-agent local/runtime environment example.
# Do not put real secrets in this file. Runtime secrets are managed in Kubernetes.

APP_ENV=ecommerce-cs-agent-dev

# Kubernetes deployment target
KUBECONFIG=~/.kube/bpg-debian12-master-public.yaml
KUBE_CONTEXT=default
KUBE_NAMESPACE=ecommerce-cs-agent-dev

# Runtime URLs
API_BASE_URL=https://api.ecommerce-cs-agent-dev.fcihome.com
ADMIN_BASE_URL=https://admin.ecommerce-cs-agent-dev.fcihome.com
TARGET_BASE_URL=https://api.ecommerce-cs-agent-dev.fcihome.com

# PostgreSQL
DATABASE_URL=postgresql://cs_agent:<from-secret>@postgres.ecommerce-cs-agent-dev.svc.cluster.local:5432/cs_agent?sslmode=disable

# Object storage
OBJECT_STORAGE_ENDPOINT=http://minio.ecommerce-cs-agent-dev.svc.cluster.local:9000
OBJECT_STORAGE_BUCKET=ecommerce-cs-agent-dev
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_PATH_STYLE=true
OBJECT_STORAGE_ACCESS_KEY_ID=<from-secret>
OBJECT_STORAGE_SECRET_ACCESS_KEY=<from-secret>

# LLM provider
LLM_API_KEY=<from-secret>
LLM_BASE_URL=<provider-base-url>
LLM_MODEL=<model-name>

# Auth/session
SESSION_SECRET=<from-secret>
JWT_SECRET=<from-secret>
AGENT_API_TOKEN=<from-secret>
ADMIN_INITIAL_EMAIL=<admin@example.com>
ADMIN_INITIAL_PASSWORD_HASH=<bcrypt-or-argon2-hash>

# Optional outbound proxy for business pods if LLM access requires it.
# HTTP_PROXY=http://192.168.1.198:1087
# HTTPS_PROXY=http://192.168.1.198:1087
# NO_PROXY=localhost,127.0.0.1,.svc,.cluster.local,postgres.ecommerce-cs-agent-dev.svc.cluster.local,minio.ecommerce-cs-agent-dev.svc.cluster.local
