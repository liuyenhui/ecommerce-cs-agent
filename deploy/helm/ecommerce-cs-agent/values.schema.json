{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "api": {
      "type": "object",
      "properties": {
        "cursorSigningSecretRef": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "key"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 253,
              "pattern": "^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$"
            },
            "key": {
              "type": "string",
              "minLength": 1,
              "maxLength": 253,
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          }
        }
      },
      "required": ["cursorSigningSecretRef"]
    }
  },
  "required": ["api"]
}
